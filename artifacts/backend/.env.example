# ────────────────────────────────────────────────────────────────────────────────
# Smart Tiffin Platform - Backend Environment Configuration
# ────────────────────────────────────────────────────────────────────────────────
#
# IMPORTANT: Copy this file to .env and update values for your environment.
# DO NOT commit .env to version control!
# ────────────────────────────────────────────────────────────────────────────────

# ── DATABASE CONFIGURATION (Required) ──────────────────────────────────────────

# PostgreSQL connection string
# For Neon (recommended): postgresql://user:password@host/db?sslmode=require&channel_binding=require
# For local: postgresql://postgres:password@localhost:5432/smart_tiffin_db
DATABASE_URL=postgresql://user:password@localhost:5432/smart_tiffin_db

# ── AUTHENTICATION (Required) ─────────────────────────────────────────────────

# Session signing secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=your-super-secret-session-key-here

# JWT signing secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-super-secret-jwt-key-here

# ── SERVER CONFIGURATION (Optional) ───────────────────────────────────────────

# Server port (default: 8080)
PORT=8080

# Environment mode
# Values: development, production, test
NODE_ENV=development

# CORS origin (for production, specify your frontend URL)
FRONTEND_URL=http://localhost:4173

# ── NOTIFICATIONS (Optional) ──────────────────────────────────────────────────

# Twilio SMS/WhatsApp notifications
# Leave empty to use mock mode (logs to console, doesn't send actual SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_CHANNEL=sms

# ── ERROR MONITORING (Optional) ───────────────────────────────────────────────

# Sentry error tracking (optional)
SENTRY_DSN=

# ── THIRD-PARTY INTEGRATIONS (Optional) ───────────────────────────────────────

# Future: Email service
SENDGRID_API_KEY=

# Future: Payment gateway
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ────────────────────────────────────────────────────────────────────────────────
# SETUP INSTRUCTIONS
# ────────────────────────────────────────────────────────────────────────────────
#
# 1. Database Setup:
#    a) Use Neon (recommended):
#       - Visit https://neon.tech
#       - Create new project
#       - Copy connection string
#       - Paste as DATABASE_URL (must include ?sslmode=require&channel_binding=require)
#
#    b) Use local PostgreSQL:
#       - Create database: createdb smart_tiffin_db
#       - Get connection string: postgresql://postgres:password@localhost:5432/smart_tiffin_db
#
# 2. Generate Secrets:
#    SESSION_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#    JWT_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 3. Optional: Twilio Setup (for SMS notifications):
#    - Visit https://www.twilio.com
#    - Create account
#    - Get Account SID, Auth Token, Phone Number
#
# 4. Push Database Schema:
#    pnpm --filter @workspace/db run push
#
# ────────────────────────────────────────────────────────────────────────────────
